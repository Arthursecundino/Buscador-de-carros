@app.route('/cadastro', methods=['GET', 'POST'])
def cadastro():
    if request.method == 'POST':
        nome = request.form['nome']
        email = request.form['email']
        senha = hash_senha(request.form['senha'])

        con = conectar_banco()
        cursor = con.cursor()
        try:
            cursor.execute("INSERT INTO usuarios (nome, email, senha) VALUES (%s, %s, %s)", (nome, email, senha))
            con.commit()
            flash('Cadastro realizado com sucesso! Faça seu login.', 'success')
            return redirect(url_for('tela_login'))
        except Exception as e:
            flash('Erro ao cadastrar. O e-mail informado já pode estar em uso.', 'danger')
            return redirect(url_for('cadastro'))
        finally:
            cursor.close()
            con.close()
    return render_template('cadastro_inicial.html')

@app.route('/login', methods=['GET'])
def tela_login():
    return render_template('login.html')

@app.route('/login', methods=['POST'])
def processar_login():
    email = request.form.get('email', '').strip()
    senha = request.form.get('senha', '')

    con = conectar_banco()
    cursor = con.cursor(dictionary=True)
    cursor.execute("SELECT * FROM usuarios WHERE email=%s AND senha=%s", (email, hash_senha(senha)))
    usuario = cursor.fetchone()
    cursor.close()
    con.close()

    if usuario:
        session['usuario_id'] = usuario['id']
        session['usuario_nome'] = usuario['nome']
        flash(f"Bem-vindo, {usuario['nome']}!")
        return redirect(url_for('index'))
    else:
        flash('Conta não cadastrada ou senha incorreta.', 'danger')
        return redirect(url_for('tela_login'))

@app.route('/logout')
def logout():
    session.clear()
    flash('Sessão encerrada.')
    return redirect(url_for('index'))

@app.route('/cadastro_whatsapp', methods=['GET', 'POST'])
def cadastro_whatsapp():
    if request.method == 'POST':
        nome = request.form['nome']
        tel = request.form.get('tel')

        con = conectar_banco()
        cursor = con.cursor()
        cursor.execute("INSERT INTO cadastro_whatsapp (nome_completo, whatsapp) VALUES (%s, %s)", (nome, tel))
        con.commit()
        cursor.close()
        con.close()

        flash('Inscrição realizada! Você receberá as novidades no seu WhatsApp.', 'success')
        return redirect(url_for('index'))

    return render_template('cadastro_WhatsApp.html')



@app.route('/buscar', methods=['GET'])
def buscar():

    marca = request.args.get('marca', '')
    modelo = request.args.get('modelo', '')

    con = conectar_banco()

    cursor = con.cursor(dictionary=True)

    query = """
        SELECT * FROM veiculos
        WHERE marca LIKE %s
        AND modelo LIKE %s
    """

    cursor.execute(
        query,
        (f"%{marca}%", f"%{modelo}%")
    )

    resultados = cursor.fetchall()

    cursor.close()
    con.close()

    return render_template(
        'comprar.html',
        veiculos=resultados
    )

